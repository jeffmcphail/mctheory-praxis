# Praxis environment variables -- example / template
#
# Copy this file to .env and fill in real values for each key you need.
# .env is gitignored; .env.example is the committed template.
#
# ============================================================================
# REGENERATION NOTE (post-disk-failure recovery, 2026-04-29):
# This template was reconstructed from a grep of all `os.getenv(...)` calls
# in engines/, scripts/, src/, servers/, gui/, tests/. It reflects every env
# var actually read by the codebase as of the recovery commit. A future change
# that adds a new env var should also add it here, with a stub and a one-line
# comment explaining what it's for.
#
# Each section below tells you WHERE to get / regenerate the key, with
# concrete URLs and navigation steps. Steps verified against provider docs
# as of 2026-04-29; if a UI has moved, search for "<provider> API key 2026"
# and update this file when you find the new path.
# ============================================================================
#
# Loaded by python-dotenv via load_dotenv() at the top of any script that
# needs keys. Do NOT commit a populated .env file.

# ============================================================================
# LLM PROVIDERS (used by engines/ai_ensemble.py)
# ============================================================================
# Cascade: free providers (Groq) first, then paid (DeepSeek, Anthropic, OpenAI).
# ai_ensemble.py loads via dynamic config["env_key"] lookup -- if you add a
# provider, edit ai_ensemble.py PROVIDERS list and add the key name here.
#
# Quick suggestion for budget: Groq is free forever (rate-limited).
# DeepSeek gives 5M free tokens on signup, then $0.28/M paid -- cheapest
# frontier-tier paid option. Anthropic and OpenAI are pay-as-you-go from
# the first token but have higher quality. Memory rule: cheap-scan first
# (Groq), expensive-analysis only when needed (Anthropic Opus / OpenAI o1).

# ----------------------------------------------------------------------------
# ANTHROPIC -- console.anthropic.com
# 1. Go to https://console.anthropic.com (sign in or create account)
# 2. Click "Settings" gear icon (top-right) or go directly to:
#    https://console.anthropic.com/settings/keys
# 3. Add a payment method first under "Plans & Billing" -- API is
#    pay-as-you-go, no subscription. Minimum $5 credit purchase.
# 4. In the API Keys section, click "Create Key"
# 5. Name it something like "praxis-prod" or "mcrmini1-praxis"
# 6. COPY THE KEY IMMEDIATELY -- it's only shown once. Format: sk-ant-api03-...
# 7. Optional: set a per-key spending limit while creating it
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# ----------------------------------------------------------------------------
# OPENAI -- platform.openai.com
# 1. Go to https://platform.openai.com (sign in or create account)
# 2. Click your profile icon (top-right) -> "View API keys"
#    or go directly to: https://platform.openai.com/api-keys
# 3. If first-time setup: add billing under Settings -> Billing -> Payment methods
#    Buy initial credits ($5 minimum). Pay-as-you-go from there.
# 4. Click "+ Create new secret key"
# 5. Name it (e.g., "praxis-mcrmini1") and choose permissions
#    (default "All" is fine; "Restricted" is more secure but more work)
# 6. COPY THE KEY -- only shown once. Format: sk-proj-... or sk-...
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_ME

# ----------------------------------------------------------------------------
# DEEPSEEK -- platform.deepseek.com (free 5M tokens on signup, no card)
# 1. Go to https://platform.deepseek.com (sign up with email + phone verify)
# 2. Once logged in, go directly to: https://platform.deepseek.com/api_keys
# 3. Click "Create new API key", name it
# 4. COPY THE KEY -- only shown once
# 5. Free balance auto-applies; check "Usage" / "Billing" tab to confirm
#    5M token grant. Add credit later if needed (minimum $2 top-up).
# Note: model names in our code may be "deepseek-chat" / "deepseek-reasoner"
# (deprecated 2026-07-24) or "deepseek-v4-flash" / "deepseek-v4-pro" (current).
# Verify against engines/ai_ensemble.py PROVIDERS config when refreshing.
# ----------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-REPLACE_ME

# ----------------------------------------------------------------------------
# GROQ -- console.groq.com (free tier forever, no credit card)
# 1. Go to https://console.groq.com (sign up with email or Google)
# 2. Once logged in, go directly to: https://console.groq.com/keys
# 3. Click "Create API Key", name it (e.g., "praxis-cascade")
# 4. COPY THE KEY -- only shown once. Format: gsk_...
# Free tier: 30 RPM / 6K TPM / 14,400 RPD per model. Generous enough for
# our cheap-scan pass; bottleneck is requests-per-minute, not daily total.
# Add a credit card (no minimum spend) for 10x rate limits + 25% cheaper.
# ----------------------------------------------------------------------------
GROQ_API_KEY=gsk_REPLACE_ME

# ============================================================================
# CRYPTO EXCHANGE DATA + EXECUTION
# ============================================================================
# Used by engines/crypto_data_collector.py only for AUTHENTICATED endpoints
# (funding rate history, liquidation data, account-specific endpoints).
# Public order book / trades / OHLCV work without keys -- you can run the
# trades + order_book_snapshots collectors with empty values for these.

# ----------------------------------------------------------------------------
# BINANCE -- binance.com or binance.us
# IMPORTANT: Binance.com is restricted in some jurisdictions including
# (intermittently) parts of the US and Canada. If you can't access binance.com
# from your IP, use binance.us (US) or check geographic eligibility.
# 1. Log into your Binance account at https://www.binance.com
# 2. Top-right user menu -> "Account" -> "API Management"
#    or go directly to: https://www.binance.com/en/my/settings/api-management
# 3. Click "Create API" -> select "System generated" -> name it "praxis-readonly"
# 4. Email + 2FA verification required
# 5. After creation, IMMEDIATELY edit restrictions:
#    - "Enable Reading" : YES (all we need for data collection)
#    - "Enable Spot & Margin Trading" : NO (we don't trade via Binance)
#    - "Enable Futures" : NO (unless you're rebuilding funding-strategy
#      live execution; even then, paper-trade first)
#    - "Restrict access to trusted IPs only" : YES, add your IP
# 6. COPY both API Key AND Secret. Secret is only shown once.
# ----------------------------------------------------------------------------
BINANCE_API_KEY=REPLACE_ME
BINANCE_API_SECRET=REPLACE_ME

# ============================================================================
# POLYMARKET / POLYGON ON-CHAIN
# ============================================================================
# Used by py_clob_client + web3 across:
#   engines/market_maker.py, engines/negrisk_arb.py, engines/mev_*.py,
#   engines/smart_money*.py, top-level *.py trading scripts
#
# IMPORTANT: There is no separate "Polymarket wallet." Polymarket is a smart
# contract layer on Polygon, not a custodial exchange. Your Polymarket account
# IS whatever Ethereum wallet you connected to polymarket.com -- typically
# MetaMask Account 1. Same address, same private key, same seed phrase.
# Trading balance lives as USDC.e on Polygon in that wallet.
#
# CRITICAL: POLYMARKET_PRIVATE_KEY controls a real wallet that signs trades
# and holds funds. Treat this file like cash. The wallet itself lives in
# MetaMask (browser extension), not on disk -- so it survives a disk crash
# as long as you can log back into MetaMask. The .env file is just a copy
# of the private key for programmatic access.

# ----------------------------------------------------------------------------
# POLYMARKET WALLET (private key, address)
#
# To populate POLYMARKET_PRIVATE_KEY -- export the private key from MetaMask:
#
# 1. Open the MetaMask browser extension and unlock with your password
# 2. Make sure the correct account is selected (Account 1 by default --
#    this is the one connected to polymarket.com; verify by checking the
#    USDC.e balance matches your Polymarket trading balance)
# 3. Click the three dots (kebab menu) at the top of the account view
# 4. Click "Account details"
# 5. Click "Show private key"
# 6. Re-enter your MetaMask password to confirm
# 7. Copy the 64-character hex string (no 0x prefix needed in .env)
# 8. Paste into POLYMARKET_PRIVATE_KEY below
#
# To populate POLYMARKET_WALLET and POLYMARKET_API_ADDRESS -- both are the
# public address of the same account:
#
# 1. In MetaMask, click on the account name at the top to copy the 0x address
#    (or click the copy icon next to the address)
# 2. Paste the same 0x... value into BOTH env vars below
#
# POLYMARKET_API_ADDRESS == POLYMARKET_WALLET for standard retail accounts.
# (Different only if you've set up a proxy/smart wallet -- not the default.)
#
# Verify your wallet is actually the one with Polymarket history at:
#   https://polymarket.com/profile/<your-0x-address>
#
# IF YOU EVER LOSE METAMASK ACCESS:
# Restoring MetaMask requires the 12- or 24-word seed phrase you saved when
# you first created the wallet. With the seed phrase you can restore the
# same wallet (same address, same private key, same Polymarket history)
# on any machine. Without it, the wallet is unrecoverable -- including any
# funds and any pending Polymarket positions.
# Store seed phrase in 1Password / a paper backup somewhere safe and offline.
# ----------------------------------------------------------------------------POLYMARKET_PRIVATE_KEY=REPLACE_ME
POLYMARKET_WALLET=0xREPLACE_ME
POLYMARKET_API_ADDRESS=0xREPLACE_ME

# ----------------------------------------------------------------------------
# POLYMARKET CLOB API CREDENTIALS (separate from the wallet itself)
# These are L2 keys derived from your wallet signature; they let
# py_clob_client place orders without exposing the private key per request.
#
# 1. Make sure POLYMARKET_PRIVATE_KEY above is populated first
# 2. Run: python scripts/derive_keys.py
#    (or scripts/derive_keys2.py if v1 fails -- alternate signing path)
# 3. The script will print three strings: API key, secret, passphrase
# 4. Paste them below
# 5. These can be re-derived any time by re-running the script with the
#    same private key, so they're not catastrophic if lost (wallet key is)
# ----------------------------------------------------------------------------
POLYMARKET_CLOB_API_KEY=REPLACE_ME
POLYMARKET_CLOB_API_SECRET=REPLACE_ME
POLYMARKET_CLOB_API_PASSPHRASE=REPLACE_ME

# ----------------------------------------------------------------------------
# POLYGON RPC -- read/write to Polygon mainnet
# Default: https://polygon-rpc.com (free public, often rate-limited)
# Better for execution: Alchemy or Infura with a free-tier key
#
# Alchemy path:
# 1. Go to https://www.alchemy.com -> sign up (free)
# 2. "Create new app" -> chain: Polygon, network: Mainnet, name: "praxis"
# 3. Click app -> "API key" -> use the HTTPS endpoint URL as POLYGON_RPC_URL
# 4. Format: https://polygon-mainnet.g.alchemy.com/v2/<your-api-key>
#
# Infura path:
# 1. Go to https://www.infura.io -> sign up (free)
# 2. Create new project -> Polygon Mainnet network
# 3. Use the endpoint URL with your project ID
# ----------------------------------------------------------------------------
POLYGON_RPC_URL=https://polygon-rpc.com

# ----------------------------------------------------------------------------
# POLYGONSCAN -- block explorer API for tx receipts / contract ABI
# 1. Go to https://polygonscan.com -> Sign In or create account
# 2. Account dropdown (top-right) -> "API Keys"
#    or: https://polygonscan.com/myapikey
# 3. Click "Add" -> name it "praxis"
# 4. Copy the resulting key. Free tier: 100K calls/day, 5 calls/sec.
# ----------------------------------------------------------------------------
POLYGONSCAN_API_KEY=REPLACE_ME

# Some scripts check POLYGONSCAN_API_KEY first, then fall back to POLYGON_API_KEY
# (older alias). Set POLYGON_API_KEY to the same value as POLYGONSCAN_API_KEY
# unless you have a reason to differ.
POLYGON_API_KEY=REPLACE_ME

# ----------------------------------------------------------------------------
# ARBITRUM RPC -- referenced by MEV/cross-chain code paths
# Free public RPC: https://arb1.arbitrum.io/rpc
# For production / execution: same providers (Alchemy, Infura) support
# Arbitrum One. Same setup process as Polygon path above, just select
# "Arbitrum" / "Arbitrum One" as the network in the Alchemy or Infura UI.
# ----------------------------------------------------------------------------
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ============================================================================
# KALSHI (US-regulated event prediction market)
# ============================================================================
# Referenced by some probe/scan scripts but not by core trading paths.
# Authentication is email + password, not API keys.
# Empty values are fine if you're not using Kalshi-specific code paths.
# Sign up at https://kalshi.com if you want to use Kalshi (US persons only).
KALSHI_EMAIL=
KALSHI_PASSWORD=

# ============================================================================
# EMAIL ALERTING
# ============================================================================
# Used by engines/smart_money_alerts.py, scripts/funding_alert.py, and other
# notify paths. SMTP credentials -- typical setup is a Gmail account with
# an APP-SPECIFIC PASSWORD (not your normal Gmail password).
#
# Gmail app password setup:
# 1. Enable 2-Step Verification on your Google account first (required):
#    https://myaccount.google.com/security
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select app: "Mail", device: "Other (Custom name)" -> "praxis"
# 4. Google generates a 16-character password -- copy it (no spaces)
# 5. Use that as ALERT_EMAIL_PASSWORD; ALERT_EMAIL_FROM is your full Gmail
#
# Empty values disable email alerts; the alert code degrades gracefully.
# ============================================================================
ALERT_EMAIL_FROM=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_TO=
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587

# ============================================================================
# PYTHON RUNTIME TUNING
# ============================================================================
# Read by Python interpreter, not your code.
# PYTHONWARNINGS=ignore suppresses a torrent of DeprecationWarnings from
# web3 during normal operation. Leave this unset (or remove the line) if
# you want to surface warnings during debugging.
PYTHONWARNINGS=ignore

